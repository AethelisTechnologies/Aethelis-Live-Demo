      html += '<div class="zsen"><div class="zsen-lbl">HUMIDITY</div><div class="zsen-val ' + hcl(n.hum) + '">' + n.hum + '%</div></div>';
      html += '<div class="zsen"><div class="zsen-lbl">PRESSURE</div><div class="zsen-val neutral">' + n.pres + ' hPa</div></div>';
