/* ── VITALS card accent ─────────────────────────────────────────────────── */
:root {
  --rose:   #FB7185;
  --rosebg: rgba(251,113,133,.12);
  --rosebd: rgba(251,113,133,.35);
  --cyan:   #22D3EE;
  --cyanbg: rgba(34,211,238,.12);
  --cyanbd: rgba(34,211,238,.3);
}
.zcard.vitals-green { border-left-color: var(--gr); }
.zcard.vitals-amber { border-left-color: var(--am); }
.zcard.vitals-red   { border-left-color: var(--rd); }
.zcard.vitals-offl  { border-left-color: var(--off); opacity:.7; }

/* BPM value — large, with subtle heartbeat glow when normal */
.bpm-val {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 42px; font-weight: 600; line-height: 1;
  color: var(--gr);
  text-shadow: 0 0 18px rgba(34,197,94,.45), 0 0 36px rgba(34,197,94,.18);
  transition: color .4s, text-shadow .4s;
}
.bpm-val.amber {
  color: var(--am);
  text-shadow: 0 0 18px rgba(245,158,11,.5), 0 0 36px rgba(245,158,11,.2);
}
.bpm-val.red {
  color: var(--rd);
  text-shadow: 0 0 18px rgba(239,68,68,.6), 0 0 36px rgba(239,68,68,.25);
}
.bpm-val.neutral { color: var(--tx3); text-shadow: none; }
.bpm-unit {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 13px; color: var(--tx3); letter-spacing: 1px; margin-top: 4px;
}

/* SpO2 value */
.spo2-val {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 30px; font-weight: 600; line-height: 1;
  transition: color .4s;
}
.spo2-val.green  { color: var(--cyan); }
.spo2-val.amber  { color: var(--am); }
.spo2-val.red    { color: var(--rd); }
.spo2-val.neutral{ color: var(--tx3); }

/* Finger badge */
.finger-badge {
  font-family: 'IBM Plex Mono', monospace; font-size: 11px;
  padding: 3px 10px; border-radius: 20px; display: inline-block; align-self: flex-start;
}
.finger-badge.on  { background: var(--cyanbg); border: 1px solid var(--cyanbd); color: var(--cyan); }
.finger-badge.off { background: var(--bg3); border: 1px solid var(--bdr); color: var(--tx3); }

/* Vitals tier label */
.ztier-vitals { color: var(--rose); }

/* Heartbeat animation on the pulse dot for vitals */
@keyframes heartbeat {
  0%,100% { transform: scale(1); }
  14%     { transform: scale(1.3); }
  28%     { transform: scale(1); }
  42%     { transform: scale(1.2); }
}
.zpulse.vitals-green {
  background: var(--gr);
  animation: heartbeat 0.8s ease infinite;
}
.zpulse.vitals-amber {
  background: var(--am);
  animation: heartbeat 1.2s ease infinite;
}
.zpulse.vitals-red {
  background: var(--rd);
  animation: heartbeat 0.5s ease infinite;
}


/* ── Demo alarm button ─────────────────────────────────────────────────── */
#demo-btn {
  position: fixed;
  bottom: 18px;
  right: 18px;
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: var(--rd);
  border: 2px solid rgba(239,68,68,.5);
  box-shadow: 0 0 0 0 rgba(239,68,68,.4);
  cursor: pointer;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  line-height: 1;
  transition: transform .15s, box-shadow .15s;
  opacity: 0.55;
}
#demo-btn:hover {
  opacity: 1;
  transform: scale(1.1);
  box-shadow: 0 0 0 6px rgba(239,68,68,.2);
}
#demo-btn:active {
  transform: scale(.95);
}
#demo-btn.alarming {
  opacity: 1;
  animation: demo-alarm-pulse 0.6s ease infinite;
}
#demo-toast {
  position: fixed;
  bottom: 68px;
  right: 18px;
  background: var(--bg2);
  border: 1px solid var(--rbd);
  border-radius: 10px;
  padding: 8px 14px;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 11px;
  color: var(--rd);
  letter-spacing: .5px;
  z-index: 999;
  pointer-events: none;
  opacity: 0;
  transform: translateY(6px);
  transition: opacity .25s, transform .25s;
  white-space: nowrap;
}
#demo-toast.show {
  opacity: 1;
  transform: translateY(0);
}
@keyframes demo-alarm-pulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(239,68,68,.6); }
  50%      { box-shadow: 0 0 0 10px rgba(239,68,68,0); }
}

