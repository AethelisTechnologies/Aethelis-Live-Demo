    } else {
      const f = parseFloat(c2f(n.temp));
      html += '<div class="ztier">' + n.tier + '</div>';
      html += '<div class="zname">' + n.name + '</div>';
      html += '<div class="zpres ' + (n.occ?'occ':'vac') + '">' + (n.occ?'● OCCUPIED':'○ VACANT') + '</div>';
    }
    html += '</div>';

    // ── MIDDLE COLUMN ─────────────────────────────────────
    html += '<div class="zmid">';
    if(isVit) {
      const bc = n.finger ? bpmCl(n.bpm) : 'neutral';
      const oc = n.finger ? spo2Cl(n.spo2) : 'neutral';
      // BPM — large display
      html += '<div class="zsen" style="justify-content:center;align-items:center;text-align:center;border-right:1px solid var(--bdr);">';
      html += '<div class="zsen-lbl">HEART RATE</div>';
      html += '<div class="bpm-val ' + bc + '">' + (n.finger?n.bpm:'—') + '</div>';
      html += '<div class="bpm-unit">BPM</div>';
      html += '</div>';
      // SpO2
      html += '<div class="zsen">';
      html += '<div class="zsen-lbl">SpO₂</div>';
      html += '<div class="spo2-val ' + oc + '">' + (n.finger?n.spo2+'%':'—') + '</div>';
      html += '<div class="zsen-lbl" style="margin-top:12px;margin-bottom:4px;">SIGNAL</div>';
      html += '<div class="zsen-val ' + (n.rssi>-60?'green':n.rssi>-80?'amber':'red') + '" style="font-size:16px;">' + n.rssi + ' dB</div>';
      html += '</div>';
    } else {
      const f = parseFloat(c2f(n.temp));
