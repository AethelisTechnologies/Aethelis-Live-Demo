// SUMMARY BAR
// ═══════════════════════════════════════════════════════
function renderSummary() {
  const pills=document.getElementById('sb-pills');
  const sysEl=document.getElementById('sb-sys');
  if(!pills) return;
  let h='';
  nodes.forEach(n=>{
    const sc=n.conn?n.status:'offl';
    const sh=(n.name.split('—')[1]||n.name).trim();
    let valText, valColor;
    if(!n.conn){
      valText='OFFLINE'; valColor='neutral';
    } else if(n.type==='vitals'){
      valText=n.finger?(n.bpm+' BPM'):'—';
      valColor=n.finger?bpmCl(n.bpm):'neutral';
    } else {
      const f=parseFloat(c2f(n.temp));
      valText=c2f(n.temp)+'°F';
      valColor=tcl(f);
    }
    h+='<div class="sb-pill '+sc+'" data-action="jump" data-id="'+n.id+'">';
    h+='<div class="sb-dot '+sc+'"></div>';
    h+='<span class="sb-name">'+sh+'</span>';
    h+='<span class="sb-temp '+valColor+'">'+valText+'</span>';
    h+='</div>';
  });
  pills.innerHTML=h;
  const sys=nodes.some(n=>n.status==='red')?'red':nodes.some(n=>n.status==='amber')?'amber':'green';
  sysEl.className=sys;
  sysEl.textContent=sys==='red'?'ALERT':sys==='amber'?'WARNING':'NORMAL';
}
function jumpTo(id) {
  const p=Math.floor((id-1)/PER_PAGE);
  if(p!==pg){pg=p;renderClinical();renderDots();}
  setTimeout(()=>{
    const cards=document.querySelectorAll('.zcard');
    const idx=(id-1)%PER_PAGE;
    if(cards[idx]) cards[idx].scrollIntoView({behavior:'smooth',block:'nearest'});
  },80);
}

