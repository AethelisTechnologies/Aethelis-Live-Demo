// ═══════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════
const c2f = c => (c*9/5+32).toFixed(1);
const up2s = s => Math.floor(s/3600)+'h '+Math.floor((s%3600)/60)+'m';
const t2s = d => (d||new Date()).toLocaleTimeString('en-US',{hour12:false,hour:'2-digit',minute:'2-digit',second:'2-digit'});
const ago = d => {
  if(!d) return '—';
  const s=Math.floor((Date.now()-d)/1000);
  if(s<10) return 'just now'; if(s<60) return s+'s ago'; return Math.floor(s/60)+'m ago';
};
const tcl = f => f>82?'red':f>78?'amber':'green';
const hcl = h => h>68?'red':h>62?'amber':'green';
const rcl = r => r>-60?'g':r>-80?'w':'b';
const pcl = p => p<2?'g':p<4?'w':'b';
const bcl = p => p>50?'var(--gr)':p>20?'var(--am)':'var(--rd)';
// Vitals color helpers
const bpmCl  = b => b>120||b<50?'red':b>100||b<60?'amber':'green';
const spo2Cl = o => o<90?'red':o<94?'amber':'green';

function calcStatus(n) {
  if(!n.conn) return 'offl';
  if(n.type==='vitals') {
    if(!n.finger) return 'amber';            // no contact
    if(n.bpm>120||n.bpm<50||n.spo2<90) return 'red';
    if(n.bpm>100||n.bpm<60||n.spo2<94) return 'amber';
    return 'green';
  }
  const f=parseFloat(c2f(n.temp));
  if(f>82||n.hum>68||n.pl>4) return 'red';
  if(f>78||n.hum>62||n.pl>2) return 'amber';
  return 'green';
}
function addLog(zone,type,msg) {
  LOG.unshift({t:new Date(),zone,type,msg});
  if(LOG.length>150) LOG.pop();
  if(mode==='it') renderLog();
}

// ═══════════════════════════════════════════════════════
// SPARKLINE
// ═══════════════════════════════════════════════════════
function spark(data, col) {
  if(!data||data.length<2) return '';
  const w=100,h=24,p=2;
  const mn=Math.min(...data),mx=Math.max(...data),rng=mx-mn||.01;
  const pts=data.map((v,i)=>{
    const x=p+(i/(data.length-1))*(w-p*2);
    const y=h-p-((v-mn)/rng)*(h-p*2);
    return x.toFixed(1)+','+y.toFixed(1);
  }).join(' ');
  const last=pts.split(' ').slice(-1)[0];
  const lx=last.split(',')[0],ly=last.split(',')[1];
  const area=`${p},${h-p} ${pts} ${lx},${h-p}`;
  const gid='g'+(Math.random()*9999|0);
  return `<svg width="${w}" height="${h}" viewBox="0 0 ${w} ${h}"><defs>
    <linearGradient id="${gid}" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="${col}" stop-opacity=".25"/>
      <stop offset="100%" stop-color="${col}" stop-opacity="0"/>
    </linearGradient></defs>
    <polygon points="${area}" fill="url(#${gid})"/>
    <polyline points="${pts}" fill="none" stroke="${col}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    <circle cx="${lx}" cy="${ly}" r="2.5" fill="${col}"/>
  </svg>`;
}

// ═══════════════════════════════════════════════════════
// NEXT STEPS
// ═══════════════════════════════════════════════════════
const NS = {
