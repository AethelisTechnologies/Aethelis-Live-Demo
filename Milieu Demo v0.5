  vsoa:{lv:'amber',title:'⚠ SpO2 BELOW 94%',
    cl:['Blood oxygen saturation below normal range (95–100%).',
        'Verify sensor placement and reposition on a clean fingertip.',
        'Monitor closely — if declining, escalate to clinical staff.'],
    it:['SpO2 <94% amber threshold. Check for motion artifact or poor contact.',
        'Confirm finger is warm — cold extremities reduce MAX30102 accuracy.']},
  vnf:{lv:'amber',title:'⚠ NO FINGER DETECTED',
    cl:['Vitals Ganglion not detecting finger contact.',
        'Ask subject to place finger firmly on the sensor.',
        'No valid BPM or SpO2 readings available while contact is lost.'],
    it:['MAX30102 finger detection lost. Subject may have removed finger.',
        'Sensor reports bpm:0, spo2:0 when no contact — ignore those readings.',
        'Check Cardputer display for local confirmation of sensor state.']},
};
function nsHtml(n) {
  const steps=[];
  if(!n.conn){ steps.push(NS.of); }
  else if(n.type==='vitals') {
    if(!n.finger) steps.push(NS.vnf);
    else {
      if(n.bpm>120)        steps.push(NS.vhr);
      else if(n.bpm<50)    steps.push(NS.vlr);
      else if(n.bpm>100)   steps.push(NS.vha);
      else if(n.bpm<60)    steps.push(NS.vla);
      if(n.spo2<90)        steps.push(NS.vso);
      else if(n.spo2<94)   steps.push(NS.vsoa);
    }
  } else {
    const f=parseFloat(c2f(n.temp));
    if(f>82) steps.push(NS.tr); else if(f>78) steps.push(NS.ta);
    if(n.hum>68) steps.push(NS.hr); else if(n.hum>62) steps.push(NS.ha);
  }
  if(!steps.length) return '';
  return steps.map(ns=>{
    const msgs=mode==='clinical'?ns.cl:ns.it;
    let h='<div class="ns-block">';
    h+='<div class="ns-head '+ns.lv+'">'+ns.title+'</div>';
    h+='<div class="ns-body">';
    msgs.forEach((m,i)=>{h+='<div class="ns-row"><span class="ns-n">'+(i+1)+'.</span><span>'+m+'</span></div>';});
    h+='</div></div>';
    return h;
  }).join('');
}

