// UTILITIES
// ═══════════════════════════════════════════════════════
function toggleTheme(){
  theme=theme==='dark'?'light':'dark';
  document.documentElement.setAttribute('data-theme',theme);
  document.getElementById('tbtn').textContent=theme==='dark'?'🌙':'☀️';
}
function clearLog(){LOG=[];addLog('SYSTEM','INFO','Log cleared');}
function exportLog(){
  const lines=['Time,Zone,Type,Event'];
  LOG.forEach(e=>lines.push([t2s(e.t),e.zone,e.type,'"'+e.msg+'"'].join(',')));
  const a=Object.assign(document.createElement('a'),{
    href:URL.createObjectURL(new Blob([lines.join('\n')],{type:'text/csv'})),
    download:'milieu-'+new Date().toISOString().slice(0,10)+'.csv'});
  a.click();URL.revokeObjectURL(a.href);
  addLog('SYSTEM','EXPORT','Event log exported');
}
function updClock(){
  const e=document.getElementById('clk');
  if(e) e.textContent=new Date().toLocaleTimeString('en-US',{hour12:false,hour:'2-digit',minute:'2-digit'});
}
async function wakeLock(){try{if('wakeLock' in navigator)await navigator.wakeLock.request('screen');}catch(e){}}



// ═══════════════════════════════════════════════════════
// DEMO ALARM — simulates a zone going critical and recovering
// ═══════════════════════════════════════════════════════
var demoTimer = null;
function triggerDemoAlarm() {
  if(demoTimer) return; // already running

  var btn   = document.getElementById('demo-btn');
  var toast = document.getElementById('demo-toast');

  // Pick a random env node to alarm (not vitals)
  var envNodes = nodes.filter(function(n){ return n.type !== 'vitals' && n.conn; });
  if(!envNodes.length) return;
  var target = envNodes[Math.floor(Math.random() * envNodes.length)];
  var idx    = nodes.findIndex(function(n){ return n.id === target.id; });

  // Save original values
  var origTemp   = nodes[idx].temp;
  var origStatus = nodes[idx].status;

  // Spike temp to trigger red threshold (>82°F = >27.8°C)
  nodes[idx].temp   = 28.2;
  nodes[idx].status = 'red';
  nodes[idx].seen   = new Date();

  addLog(nodes[idx].name, 'ALERT', 'DEMO — Temperature critical: ' + c2f(nodes[idx].temp) + '°F');

  // Visual feedback
  btn.classList.add('alarming');
  btn.textContent = '🔴';
  toast.classList.add('show');
  toast.textContent = 'DEMO ALARM — ' + nodes[idx].name + ' — auto-clearing in 8s';

  renderAll();

  // Auto-recover after 8 seconds
  demoTimer = setTimeout(function() {
    nodes[idx].temp   = origTemp;
    nodes[idx].status = calcStatus(nodes[idx]);
    nodes[idx].seen   = new Date();
    addLog(nodes[idx].name, 'STATUS', 'DEMO — Alarm cleared, returning to normal');

    btn.classList.remove('alarming');
    btn.textContent = '🚨';
    toast.classList.remove('show');
    demoTimer = null;
    renderAll();
  }, 8000);
}

// ═══════════════════════════════════════════════════════
// EVENT LISTENERS — all click handling, no inline onclick
// ═══════════════════════════════════════════════════════
function initEvents() {
  function on(id,ev,fn){var e=document.getElementById(id);if(e)e.addEventListener(ev,fn);}
  function onq(sel,ev,fn){var e=document.querySelector(sel);if(e)e.addEventListener(ev,fn);}
  function del(id,attr,fn){
    var el=document.getElementById(id);if(!el)return;
    el.addEventListener('click',function(e){var t=e.target.closest('['+attr+']');if(t)fn(t);});
  }
  onq('.mtog','click',function(e){var b=e.target.closest('[data-mode]');if(b)setMode(b.dataset.mode);});
  onq('.dwell-wrap','click',function(e){var b=e.target.closest('[data-dwell]');if(b)setDwell(parseInt(b.dataset.dwell));});
  on('rot-btn',    'click',toggleRot);
  on('rot-bar-btn','click',toggleRotBar);
  on('tbtn',       'click',toggleTheme);
  on('export-btn', 'click',exportLog);
  on('clear-btn',  'click',clearLog);
  del('clin-grid','data-action',function(t){if(t.dataset.action==='detail'){var id=parseInt(t.dataset.id);if(!isNaN(id))toggleDetail(id);}});
  del('sb-pills','data-action',function(t){if(t.dataset.action==='jump'){var id=parseInt(t.dataset.id);if(!isNaN(id))jumpTo(id);}});
  del('pdots','data-action',function(t){if(t.dataset.action==='page'){var p=parseInt(t.dataset.pg);if(!isNaN(p))goPg(p);}});
  del('ncards','data-action',function(t){if(t.dataset.action==='detail-it'){var id=parseInt(t.dataset.id);if(!isNaN(id))toggleDetailIT(id);}});
  on('demo-btn','click',triggerDemoAlarm);
}

