// ═══════════════════════════════════════════════════════
let nodes = [
  {id:1,name:'Zone 1 — OR Suite',nodeId:'!04083034',nodeName:'AETH Hub',
   tier:'TIER 1 — OPERATING ROOM',temp:21.2,hum:52,pres:1013.0,voc:.30,
