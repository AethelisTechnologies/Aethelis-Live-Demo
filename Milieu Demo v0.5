<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>Milieu v0.5 — Aethelis</title>
<link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
[data-theme="dark"] {
  --bg:#0B1623;--bg2:#132030;--bg3:#1C2E42;--bg4:#243547;
  --bdr:#243547;--bdr2:#3D5468;
  --tx:#F4F7F9;--tx2:#D8E2EA;--tx3:#8FA4B4;--tx4:#3D5468;
  --card:#132030;--shad:rgba(0,0,0,.4);
}
[data-theme="light"] {
  --bg:#EEF2F6;--bg2:#FFFFFF;--bg3:#F4F7FA;--bg4:#E2E8F0;
  --bdr:#CBD5E1;--bdr2:#94A3B8;
  --tx:#0F172A;--tx2:#1E293B;--tx3:#475569;--tx4:#CBD5E1;
  --card:#FFFFFF;--shad:rgba(0,0,0,.08);
}
:root {
  --teal:#1DBFA0;--teal2:#158F78;
  --gr:#22C55E;--gbg:rgba(34,197,94,.12);--gbd:rgba(34,197,94,.3);
  --am:#F59E0B;--abg:rgba(245,158,11,.12);--abd:rgba(245,158,11,.3);
  --rd:#EF4444;--rbg:rgba(239,68,68,.12);--rbd:rgba(239,68,68,.3);
  --off:#4B6070;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;overflow:hidden;}
body{height:100%;display:flex;flex-direction:column;background:var(--bg);color:var(--tx);font-family:'IBM Plex Sans',sans-serif;border-top:3px solid var(--teal);}

/* ── TOP BARS ── */
#sim-banner{background:var(--abg);border-bottom:1px solid var(--abd);padding:6px 16px;text-align:center;font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--am);flex-shrink:0;}
#sim-banner.hidden{display:none;}

#summary-bar{display:flex;align-items:center;gap:8px;padding:8px 12px;background:var(--bg2);border-bottom:1px solid var(--bdr);flex-shrink:0;}
#summary-bar.hidden{display:none;}
#sb-pills{display:flex;gap:6px;flex:1;}
.sb-pill{flex:1;display:flex;align-items:center;gap:7px;background:var(--bg3);border:1px solid var(--bdr);border-radius:8px;padding:7px 10px;cursor:pointer;min-width:0;transition:border-color .3s,background .3s;}
.sb-pill.green{border-color:var(--gbd);background:var(--gbg);}
.sb-pill.amber{border-color:var(--abd);background:var(--abg);}
.sb-pill.red{border-color:var(--rbd);background:var(--rbg);}
.sb-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}
.sb-dot.green{background:var(--gr);animation:pg 2.5s ease infinite;}
.sb-dot.amber{background:var(--am);animation:pa 2.5s ease infinite;}
.sb-dot.red{background:var(--rd);animation:pr 1.8s ease infinite;}
.sb-dot.offl{background:var(--off);}
.sb-name{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--tx2);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.sb-temp{font-family:'IBM Plex Mono',monospace;font-size:13px;font-weight:600;white-space:nowrap;}
.sb-temp.green{color:var(--gr);}.sb-temp.amber{color:var(--am);}.sb-temp.red{color:var(--rd);}.sb-temp.neutral{color:var(--tx3);}
#sb-sys{font-family:'IBM Plex Mono',monospace;font-size:12px;font-weight:600;padding:5px 10px;border-radius:6px;white-space:nowrap;}
#sb-sys.green{background:var(--gbg);color:var(--gr);border:1px solid var(--gbd);}
#sb-sys.amber{background:var(--abg);color:var(--am);border:1px solid var(--abd);}
#sb-sys.red{background:var(--rbg);color:var(--rd);border:1px solid var(--rbd);}

#rot-bar{display:flex;align-items:center;gap:10px;padding:7px 12px;background:var(--bg2);border-bottom:1px solid var(--bdr);flex-shrink:0;}
#rot-bar.hidden{display:none;}
.rot-lbl{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:1.5px;color:var(--tx3);flex-shrink:0;}
.dwell-wrap{display:flex;gap:4px;}
.dw{font-family:'IBM Plex Mono',monospace;font-size:10px;padding:4px 10px;border-radius:6px;cursor:pointer;background:var(--bg3);border:1px solid var(--bdr);color:var(--tx3);}
.dw.on{background:var(--teal2);border-color:var(--teal2);color:#fff;font-weight:600;}
.rot-prog{flex:1;height:2px;background:var(--bdr);border-radius:2px;overflow:hidden;}
.rot-fill{height:100%;background:var(--teal);width:0%;border-radius:2px;}
.rot-fill.go{transition:width linear;}
.pdots{display:flex;gap:5px;align-items:center;}
.pdot{width:7px;height:7px;border-radius:50%;background:var(--bdr2);cursor:pointer;}
.pdot.on{background:var(--teal);transform:scale(1.3);}
#rot-btn{font-family:'IBM Plex Mono',monospace;font-size:10px;padding:5px 12px;border-radius:6px;cursor:pointer;white-space:nowrap;background:var(--gbg);border:1px solid var(--gbd);color:var(--gr);}
#rot-btn.paused{background:var(--bg3);border-color:var(--bdr);color:var(--tx3);}

header{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;background:var(--bg2);border-bottom:1px solid var(--bdr);flex-shrink:0;gap:10px;box-shadow:0 2px 12px rgba(0,0,0,.15);}
.brand{display:flex;align-items:baseline;gap:7px;}
.brand-n{font-family:'Libre Baskerville',serif;font-size:20px;font-weight:700;}
.brand-b{font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--tx3);letter-spacing:1.5px;}
.connw{display:flex;align-items:center;gap:5px;}
.cdot{width:8px;height:8px;border-radius:50%;}
.cdot.live{background:var(--gr);animation:pg 2s ease infinite;}
.cdot.sim{background:var(--am);animation:pa 2s ease infinite;}
.clbl{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--tx3);}
.hdr-r{display:flex;align-items:center;gap:8px;}
.mtog{display:flex;background:var(--bg3);border:1px solid var(--bdr);border-radius:8px;overflow:hidden;}
.mbtn{font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:1px;padding:7px 14px;background:transparent;border:none;color:var(--tx3);cursor:pointer;}
.mbtn.on{background:var(--teal2);color:#fff;font-weight:600;}
.ibtn{width:34px;height:34px;border-radius:8px;background:var(--bg3);border:1px solid var(--bdr);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:15px;line-height:1;}
.clk{font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--tx3);}

/* ── PAGE / VIEWS ── */
#page{flex:1;overflow:hidden;display:flex;flex-direction:column;min-height:0;}
.view{display:none;flex:1;overflow-y:auto;padding:10px;flex-direction:column;min-height:0;}
.view.on{display:flex;}

/* ── CLINICAL GRID — cards stacked top to bottom ── */
#clin-grid{display:flex;flex-direction:column;gap:8px;flex:1;min-height:0;}

/* ── ZONE CARD — horizontal strip ── */
.zcard{
  flex:1;min-height:0;
  display:flex;flex-direction:column;
  background:var(--card);border-radius:14px;overflow:hidden;
  border:1px solid var(--bdr);border-left:5px solid var(--bdr);
  box-shadow:0 2px 8px var(--shad);
}
.zcard.green{border-left-color:var(--gr);}
.zcard.amber{border-left-color:var(--am);}
.zcard.red{border-left-color:var(--rd);}
.zcard.offl{border-left-color:var(--off);opacity:.7;}

/* MAIN ROW — the clickable horizontal strip inside each card */
.zmain{
  flex:1;min-height:0;
  display:grid;
  grid-template-columns:200px 1fr 170px;
  cursor:pointer;
  transition:background .15s ease;
}
.zmain:hover{background:rgba(29,191,160,.05);}
.zmain:active{background:rgba(29,191,160,.12);}

/* LEFT */
.zleft{padding:14px 16px;display:flex;flex-direction:column;justify-content:center;gap:8px;border-right:1px solid var(--bdr);}
.ztier{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:2px;color:var(--tx3);}
.zname{font-family:'Libre Baskerville',serif;font-size:24px;font-weight:700;color:var(--tx);line-height:1.15;}
.zpres{font-family:'IBM Plex Mono',monospace;font-size:11px;padding:3px 10px;border-radius:20px;display:inline-block;align-self:flex-start;}
.zpres.occ{background:var(--gbg);border:1px solid var(--gbd);color:var(--gr);}
.zpres.vac{background:var(--bg3);border:1px solid var(--bdr);color:var(--tx3);}

/* MIDDLE — sensors */
.zmid{display:flex;align-items:stretch;}
.zsen{flex:1;padding:14px 10px;border-right:1px solid var(--bdr);display:flex;flex-direction:column;justify-content:center;}
.zsen:last-child{border-right:none;}
.zsen-lbl{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:1.5px;color:var(--tx3);margin-bottom:8px;}
.zsen-val{font-family:'IBM Plex Mono',monospace;font-size:30px;font-weight:600;line-height:1;}
.zsen-val.green{color:var(--gr);}.zsen-val.amber{color:var(--am);}.zsen-val.red{color:var(--rd);}.zsen-val.neutral{color:var(--tx2);}

/* RIGHT — status + sparkline */
.zright{padding:14px 16px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;border-left:1px solid var(--bdr);}
.zstatus{font-family:'IBM Plex Mono',monospace;font-size:34px;font-weight:600;letter-spacing:1px;line-height:1;transition:color .4s ease,text-shadow .4s ease;}
.zstatus.green{color:var(--gr);text-shadow:0 0 20px rgba(34,197,94,.5),0 0 40px rgba(34,197,94,.2);}
.zstatus.amber{color:var(--am);text-shadow:0 0 20px rgba(245,158,11,.5),0 0 40px rgba(245,158,11,.2);}
.zstatus.red{color:var(--rd);text-shadow:0 0 20px rgba(239,68,68,.6),0 0 40px rgba(239,68,68,.25);}
.zstatus.offl{color:var(--off);text-shadow:none;}
.zpulse{width:11px;height:11px;border-radius:50%;}
.zpulse.green{background:var(--gr);animation:pg 2.5s ease infinite;}
.zpulse.amber{background:var(--am);animation:pa 2.5s ease infinite;}
.zpulse.red{background:var(--rd);animation:pr 1.8s ease infinite;}
.zpulse.offl{background:var(--off);}
.zspark-lbl{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:1px;color:var(--tx3);}
.zts-lbl{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:1px;color:var(--tx3);text-align:center;}
.zts-val{font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--tx2);text-align:center;}

/* EXPAND BUTTON — full width, sits below main row */
.zexpand{
  display:block;width:100%;flex-shrink:0;
  font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:1px;
  color:var(--tx3);text-align:right;
  background:var(--bg3);border:none;border-top:1px solid var(--bdr);
  padding:6px 14px;cursor:pointer;
  transition:color .15s,background .15s;
}
.zexpand:hover{color:var(--teal);background:var(--bg4);}
.zexpand.open{color:var(--teal);background:var(--bg4);}

/* DETAIL PANEL — below expand button */
/* Slide-down animation for detail panels */
@keyframes slideDown{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}
.zdetail{display:none;flex-shrink:0;padding:14px;background:var(--bg3);border-top:1px solid var(--bdr);}
.zdetail.open{display:block;animation:slideDown .2s ease forwards;}
.det-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:10px;}
.det-box{background:var(--bg2);border-radius:8px;padding:10px;text-align:center;}
.det-lbl{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:1px;color:var(--tx3);margin-bottom:4px;}
.det-val{font-family:'IBM Plex Mono',monospace;font-size:16px;font-weight:600;color:var(--tx2);}
.det-val.green{color:var(--gr);}.det-val.amber{color:var(--am);}.det-val.red{color:var(--rd);}
.ns-block{border-radius:8px;overflow:hidden;border:1px solid var(--bdr);margin-top:8px;}
.ns-head{padding:8px 12px;font-family:'IBM Plex Mono',monospace;font-size:10px;font-weight:600;letter-spacing:1px;}
.ns-head.amber{background:var(--abg);color:var(--am);border-bottom:1px solid var(--abd);}
.ns-head.red{background:var(--rbg);color:var(--rd);border-bottom:1px solid var(--rbd);}
.ns-body{background:var(--bg2);padding:8px 12px;}
.ns-row{display:flex;gap:8px;padding:5px 0;border-bottom:1px solid var(--bdr);font-size:13px;color:var(--tx2);line-height:1.5;}
.ns-row:last-child{border-bottom:none;padding-bottom:0;}
.ns-n{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--teal);font-weight:600;flex-shrink:0;margin-top:2px;}

/* Clinical footer */
#clin-footer{flex-shrink:0;display:flex;justify-content:space-around;background:var(--card);border:1px solid var(--bdr);border-radius:10px;padding:8px 12px;margin-top:6px;gap:6px;}
.cf-i{display:flex;flex-direction:column;gap:1px;text-align:center;}
.cf-l{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:1px;color:var(--tx3);}
.cf-v{font-family:'IBM Plex Mono',monospace;font-size:14px;font-weight:600;color:var(--tx2);}
.cf-v.green{color:var(--gr);}.cf-v.amber{color:var(--am);}.cf-v.red{color:var(--rd);}

/* ── IT VIEW ── */
.it-sec{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:2px;color:var(--teal);margin-bottom:8px;}
.mesh-sum{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;background:var(--card);border:1px solid var(--bdr);border-radius:10px;padding:12px;margin-bottom:12px;}
.ms-v{font-family:'IBM Plex Mono',monospace;font-size:18px;font-weight:600;color:var(--teal);margin-bottom:2px;text-align:center;}
.ms-l{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:1px;color:var(--tx3);text-align:center;}
.ncard{
  display:flex;flex-direction:column;
  background:var(--card);border:1px solid var(--bdr);border-radius:10px;
  margin-bottom:8px;overflow:hidden;cursor:pointer;
}
.ncard:hover{background:rgba(29,191,160,.03);}
.ncard-row{
  display:grid;grid-template-columns:auto 1fr auto auto;
  gap:10px;align-items:center;padding:12px 14px;
}
.ncard-expand{
  display:block;width:100%;padding:5px 14px;text-align:right;
  font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:1px;
  color:var(--tx4);background:var(--bg3);border:none;border-top:1px solid var(--bdr);cursor:pointer;
  transition:color .15s,background .15s;
}
.ncard-expand:hover{color:var(--teal);background:var(--bg4);}
.ncard-expand.open{color:var(--teal);background:var(--bg4);}
.ncard-detail{
  display:none;padding:12px 14px;
  background:var(--bg3);border-top:1px solid var(--bdr);
}
.ncard-detail.open{display:block;animation:slideDown .2s ease forwards;}
.ndet-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;}
.ndet-box{background:var(--bg2);border-radius:8px;padding:10px;text-align:center;}
.ndet-lbl{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:1px;color:var(--tx3);margin-bottom:4px;}
.ndet-val{font-family:'IBM Plex Mono',monospace;font-size:15px;font-weight:600;color:var(--tx2);}
.ndet-val.green{color:var(--gr);}.ndet-val.amber{color:var(--am);}.ndet-val.red{color:var(--rd);}
.nid{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--teal);background:rgba(29,191,160,.1);border:1px solid rgba(29,191,160,.2);border-radius:6px;padding:5px 8px;white-space:nowrap;}
.nname{font-size:14px;font-weight:600;color:var(--tx);}
.nmeta{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--tx3);margin-top:2px;}
.nsigs{display:flex;flex-direction:column;gap:3px;align-items:flex-end;}
.spill{font-family:'IBM Plex Mono',monospace;font-size:10px;font-weight:500;padding:2px 7px;border-radius:5px;white-space:nowrap;}
.spill.g{background:var(--gbg);color:var(--gr);border:1px solid var(--gbd);}
.spill.w{background:var(--abg);color:var(--am);border:1px solid var(--abd);}
.spill.b{background:var(--rbg);color:var(--rd);border:1px solid var(--rbd);}
.batwrap{display:flex;flex-direction:column;align-items:center;gap:3px;}
.baticon{position:relative;width:22px;height:11px;border:2px solid var(--bdr2);border-radius:2px;overflow:hidden;}
.batfill{height:100%;border-radius:1px;}
.batpct{font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--tx3);}
.elog{background:var(--card);border:1px solid var(--bdr);border-radius:10px;overflow:hidden;}
.elog-hdr{display:flex;justify-content:space-between;align-items:center;padding:10px 14px;border-bottom:1px solid var(--bdr);}
.elog-title{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:2px;color:var(--teal);}
.elog-acts{display:flex;gap:6px;}
.elog-btn{font-family:'IBM Plex Mono',monospace;font-size:10px;padding:4px 10px;border-radius:5px;cursor:pointer;border:none;}
.elog-btn.ex{background:var(--gbg);border:1px solid var(--gbd);color:var(--gr);}
.elog-btn.cl{background:var(--rbg);border:1px solid var(--rbd);color:var(--rd);}
.elog-cols{display:grid;grid-template-columns:68px 58px 85px 1fr;gap:6px;padding:6px 14px;background:var(--bg3);border-bottom:1px solid var(--bdr);}
.elog-col{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:1px;color:var(--tx4);}
.elog-body{max-height:180px;overflow-y:auto;}
.elog-row{display:grid;grid-template-columns:68px 58px 85px 1fr;gap:6px;padding:6px 14px;border-bottom:1px solid var(--bdr);align-items:center;}
.elog-row:last-child{border-bottom:none;}
.elog-t{font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--tx3);}
.elog-ty{font-family:'IBM Plex Mono',monospace;font-size:9px;font-weight:600;}
.elog-ty.START,.elog-ty.INFO{color:var(--teal);}
.elog-ty.ALERT{color:var(--rd);}
.elog-ty.WARN{color:var(--am);}
.elog-ty.STATUS,.elog-ty.EXPORT{color:var(--gr);}
.elog-z{font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--tx2);}
.elog-m{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--tx2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}

/* ── SETUP VIEW ── */
.scard{background:var(--card);border:1px solid var(--bdr);border-radius:12px;overflow:hidden;margin-bottom:12px;}
.scard-head{background:var(--teal2);padding:14px 18px;}
.scard-title{font-family:'Libre Baskerville',serif;font-size:18px;font-weight:700;color:#fff;}
.scard-sub{font-family:'IBM Plex Mono',monospace;font-size:10px;color:rgba(255,255,255,.75);margin-top:3px;}
.scard-body{padding:14px 18px;}
.ssec{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:2px;color:var(--teal);margin-bottom:10px;}
.sstep{display:flex;gap:12px;align-items:flex-start;margin-bottom:12px;}
.snum{width:28px;height:28px;border-radius:50%;background:var(--teal2);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'IBM Plex Mono',monospace;font-size:13px;font-weight:600;color:#fff;}
.stitle{font-size:14px;font-weight:600;color:var(--tx);margin-bottom:3px;}
.sbody{font-size:12px;color:var(--tx3);line-height:1.6;}
.scode{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--gr);background:var(--bg3);padding:5px 10px;border-radius:5px;display:inline-block;margin-top:5px;line-height:1.7;}
.nrow{display:grid;grid-template-columns:auto 1fr auto;gap:10px;align-items:center;background:var(--bg3);border-radius:8px;padding:10px 12px;margin-bottom:6px;}
.nbadge{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--teal);background:rgba(29,191,160,.1);border:1px solid rgba(29,191,160,.2);border-radius:5px;padding:4px 8px;}
.nrole{font-family:'IBM Plex Mono',monospace;font-size:10px;padding:3px 7px;border-radius:5px;}
.nrole.hub{background:rgba(29,191,160,.15);color:var(--teal);border:1px solid rgba(29,191,160,.3);}
.nrole.mesh{background:var(--gbg);color:var(--gr);border:1px solid var(--gbd);}
.trow{background:var(--bg3);border-radius:8px;padding:10px 12px;margin-bottom:6px;}
.tq{font-size:13px;font-weight:600;color:var(--am);margin-bottom:4px;}
.ta{font-size:12px;color:var(--tx3);line-height:1.5;}

/* ── ANIMATIONS ── */
@keyframes pg{0%,100%{box-shadow:0 0 0 0 rgba(34,197,94,.4)}50%{box-shadow:0 0 0 7px rgba(34,197,94,0)}}
@keyframes pa{0%,100%{box-shadow:0 0 0 0 rgba(245,158,11,.4)}50%{box-shadow:0 0 0 7px rgba(245,158,11,0)}}
