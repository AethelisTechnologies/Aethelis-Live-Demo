  const alts=nodes.filter(n=>n.status==='red').length;
  const sys=alts>0?'red':nodes.some(n=>n.status==='amber')?'amber':'green';
  const sl=sys==='red'?'ALERT':sys==='amber'?'WARNING':'NORMAL';
  const avgF=(nodes.reduce((s,n)=>s+parseFloat(c2f(n.temp)),0)/nodes.length).toFixed(1);
  const avgH=Math.round(nodes.reduce((s,n)=>s+n.hum,0)/nodes.length);
