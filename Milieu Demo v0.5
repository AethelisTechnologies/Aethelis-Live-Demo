// ═══════════════════════════════════════════════════════
// ROTATION
// ═══════════════════════════════════════════════════════
function totPg(){return Math.max(1,Math.ceil(nodes.length/PER_PAGE));}
function toggleRotBar(){
  rotShown=!rotShown;
  document.getElementById('rot-bar').classList.toggle('hidden',!rotShown||mode!=='clinical');
  if(rotShown&&totPg()>1&&!rotOn){rotOn=true;updRotBtn();startRot();}
  renderDots();
}
function setDwell(s){
  dwell=s;
  document.querySelectorAll('.dw').forEach(b=>b.classList.toggle('on',parseInt(b.textContent)===s));
  if(rotOn){stopRot();startRot();}
}
function toggleRot(){rotOn=!rotOn;if(rotOn)startRot();else stopRot();updRotBtn();}
function updRotBtn(){
  const b=document.getElementById('rot-btn');if(!b)return;
  b.textContent=rotOn?'⏸ PAUSE':'▶ RESUME';
  b.className=rotOn?'':'paused';
}
function startRot(){
  stopRot();
  const f=document.getElementById('rot-fill');
  if(f){f.className='rot-fill';f.style.width='0%';
    requestAnimationFrame(()=>{f.className='rot-fill go';f.style.transition='width '+dwell+'s linear';f.style.width='100%';});}
  rotTimer=setTimeout(()=>{pg=(pg+1)%totPg();renderClinical();renderDots();if(rotOn)startRot();},dwell*1000);
}
function stopRot(){
  if(rotTimer){clearTimeout(rotTimer);rotTimer=null;}
  const f=document.getElementById('rot-fill');
  if(f){f.className='rot-fill';f.style.width='0%';}
}
function renderDots(){
  const c=document.getElementById('pdots');if(!c)return;
  let h='';
  for(let i=0;i<totPg();i++) h+='<div class="pdot'+(i===pg?' on':'')+'" data-action="page" data-pg="'+i+'"></div>';
  c.innerHTML=h;
}
function goPg(p){pg=p;renderClinical();renderDots();if(rotOn){stopRot();startRot();}}

// ═══════════════════════════════════════════════════════
// SWIPE
// ═══════════════════════════════════════════════════════
let tx=0,ty=0;
document.addEventListener('touchstart',e=>{tx=e.touches[0].clientX;ty=e.touches[0].clientY;},{passive:true});
document.addEventListener('touchend',e=>{
  if(mode!=='clinical'||totPg()<=1)return;
  const dx=e.changedTouches[0].clientX-tx,dy=e.changedTouches[0].clientY-ty;
  if(Math.abs(dx)>Math.abs(dy)&&Math.abs(dx)>40){
    pg=(pg+(dx<0?1:-1)+totPg())%totPg();renderClinical();renderDots();
    if(rotOn){stopRot();startRot();}
  }
},{passive:true});

// ═══════════════════════════════════════════════════════
// MODE
// ═══════════════════════════════════════════════════════
function setMode(m){
  mode=m;
  document.querySelectorAll('.mbtn').forEach((b,i)=>b.classList.toggle('on',['clinical','it','setup'][i]===m));
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('on'));
  document.getElementById('v-'+m).classList.add('on');
  document.getElementById('summary-bar').classList.toggle('hidden',m!=='clinical');
  document.getElementById('rot-bar').classList.toggle('hidden',m!=='clinical'||!rotShown);
  if(m==='clinical'){renderClinical();renderSummary();}
  else if(m==='it') renderIT();
}

// ═══════════════════════════════════════════════════════
// WEBSOCKET
// ═══════════════════════════════════════════════════════
function wsConnect(){
  if(location.protocol==='https:'){
    addLog('SYSTEM','INFO','HTTPS mode — WebSocket disabled. Running simulation.');
    return;
  }
  try{
    wsConn=new WebSocket(WS_URL);
    wsConn.onopen=()=>{setConn('live');stopSim();addLog('SYSTEM','START','WebSocket connected — live Plexus data active');};
    wsConn.onmessage=e=>{try{
      const d=JSON.parse(e.data);
      if(d.id>=1&&d.id<=nodes.length){
        const i=d.id-1,old={...nodes[i]};
        nodes[i]={...nodes[i],...d,conn:true,seen:new Date()};
        // Update history: BPM for vitals nodes, temp for env nodes
        if(nodes[i].type==='vitals'&&d.bpm) nodes[i].hist=[...nodes[i].hist.slice(-6),d.bpm];
        else if(d.temp) nodes[i].hist=[...nodes[i].hist.slice(-6),d.temp];
        nodes[i].status=calcStatus(nodes[i]);
        if(old.status!==nodes[i].status) addLog(nodes[i].name,'STATUS',old.status+' → '+nodes[i].status);
        renderAll();
      }}catch(err){}};
    wsConn.onclose=()=>{setConn('sim');startSim();setTimeout(wsConnect,4000);};
    wsConn.onerror=()=>wsConn.close();
  }catch(e){setConn('sim');startSim();setTimeout(wsConnect,4000);}
}
function setConn(s){
  document.getElementById('cdot').className='cdot '+s;
  document.getElementById('clbl').textContent=s==='live'?'LIVE':'SIMULATION';
  document.getElementById('sim-banner').classList.toggle('hidden',s==='live');
}

// ═══════════════════════════════════════════════════════
// SIMULATION
// ═══════════════════════════════════════════════════════
function startSim(){if(!simTimer)simTimer=setInterval(tick,3500);}
function stopSim(){if(simTimer){clearInterval(simTimer);simTimer=null;}}
function tick(){
  nodes=nodes.map(n=>{
    const rssi=Math.round(n.rssi+(Math.random()-.5)*3);
    const snr=+(n.snr+(Math.random()-.5)*.3).toFixed(1);
    const pl=+(Math.max(0,n.pl+(Math.random()-.5)*.2)).toFixed(1);
    const bat=Math.max(5,Math.min(100,n.bat+(Math.random()-.5)*.1));
    let nn;

    if(n.type==='vitals') {
      // Simulate realistic BPM drift (stays near resting 72 BPM)
      const bpm=Math.round(Math.max(40,Math.min(140,n.bpm+(Math.random()-.5)*3)));
      // SpO2 stays near 98%, occasional dip
      const spo2=Math.round(Math.max(85,Math.min(100,n.spo2+(Math.random()-.48)*.4)));
      // Finger occasionally lost in simulation
      const finger=Math.random()>.97?!n.finger:n.finger;
      const hist=[...n.hist.slice(-6),bpm];
      nn={...n,bpm,spo2,finger,rssi,snr,pl,bat,hist,up:n.up+3,seen:new Date()};
      const old=n.status; nn.status=calcStatus(nn);
      if(old!==nn.status) addLog(nn.name,'STATUS',old+' → '+nn.status);
      if(bpm>120&&n.bpm<=120) addLog(nn.name,'ALERT','Heart rate exceeded 120 BPM');
      if(bpm<50&&n.bpm>=50)   addLog(nn.name,'ALERT','Heart rate below 50 BPM');
      if(spo2<94&&n.spo2>=94) addLog(nn.name,'ALERT','SpO2 below 94%');
      if(!finger&&n.finger)    addLog(nn.name,'WARN', 'Finger contact lost');
      if(finger&&!n.finger)    addLog(nn.name,'INFO', 'Finger contact restored');
    } else {
      const temp=+(n.temp+(Math.random()-.5)*.3).toFixed(1);
      const hum=Math.round(Math.max(30,Math.min(75,n.hum+(Math.random()-.5)*2)));
      const pres=+(n.pres+(Math.random()-.5)*.5).toFixed(1);
      const voc=+(Math.max(.1,Math.min(1.5,n.voc+(Math.random()-.5)*.05))).toFixed(2);
      const occ=Math.random()>.95?!n.occ:n.occ;
      const hist=[...n.hist.slice(-6),temp];
      nn={...n,temp,hum,pres,voc,rssi,snr,pl,bat,occ,hist,up:n.up+3,seen:new Date()};
      const old=n.status; nn.status=calcStatus(nn);
      if(old!==nn.status) addLog(nn.name,'STATUS',old+' → '+nn.status);
      if(parseFloat(c2f(temp))>82&&parseFloat(c2f(n.temp))<=82) addLog(nn.name,'ALERT','Temp exceeded 82°F');
      if(hum>68&&n.hum<=68) addLog(nn.name,'ALERT','Humidity exceeded 68%');
    }
    return nn;
  });
  renderAll();
}

// ═══════════════════════════════════════════════════════
// RENDER ALL
// ═══════════════════════════════════════════════════════
function renderAll(){
  if(mode==='clinical'){renderClinical();renderSummary();}
  else if(mode==='it') renderIT();
  renderDots();
}

